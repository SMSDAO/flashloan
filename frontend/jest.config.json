{
  "testEnvironment": "jsdom",
  "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
  "testMatch": [
    "**/tests/**/*.test.js",
    "**/tests/**/*.test.jsx"
  ],
  "moduleNameMapper": {
    "\\.(css|less|scss|sass)$": "identity-obj-proxy"
  },
  "transform": {
    "^.+\\.(js|jsx|ts|tsx)$": ["@swc/jest", {
      "jsc": {
        "parser": {
          "syntax": "ecmascript",
          "jsx": true
        },
        "transform": {
          "react": {
            "runtime": "automatic"
          }
        }
      }
    }]
  },
  "collectCoverageFrom": [
    "pages/**/*.{js,jsx}",
    "components/**/*.{js,jsx}",
    "!**/node_modules/**",
    "!**/tests/**"
  ]
}
