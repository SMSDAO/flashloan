# Solana Flashloan Arbitrage Configuration
# Auto-configured with sensible defaults for quick setup

# Environment
NODE_ENV=development
PORT=4000

# Solana Network Configuration
SOLANA_NETWORK=devnet
# Options: devnet, mainnet-beta, testnet

# Program IDs
PROGRAM_ID=F1ash1oanArb1trag3Program11111111111111111

# RPC Endpoints (Premium - validate before production use)
# Helius - Get your key at https://helius.dev
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# QuickNode - Get your endpoint at https://quicknode.com
QUICKNODE_RPC_URL=https://your-endpoint.solana-devnet.quiknode.pro/YOUR_TOKEN/

# Triton - Get your endpoint at https://triton.one
TRITON_RPC_URL=https://your-endpoint.rpcpool.com/YOUR_TOKEN

# Alchemy - Get your key at https://alchemy.com
ALCHEMY_RPC_URL=https://solana-devnet.g.alchemy.com/v2/YOUR_API_KEY

# Network Optimization
ENABLE_IP_ROTATION=false
ENABLE_VPN=false
PROXY_LIST=

# Example proxy format: http://user:pass@proxy1.example.com:8080,http://proxy2.example.com:8080

# Security
KEY_ENCRYPTION_KEY=auto-generated-dev-key-replace-in-production-with-secure-random-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-domain.vercel.app
REQUIRE_AUTH=false

# Fee Configuration
MIN_TIP_LAMPORTS=1000
MAX_TIP_LAMPORTS=100000
PRIORITY_FEE_PERCENTILE=75

# Jito Configuration
JITO_TIP_ACCOUNT=T1pXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles

# Admin Configuration
ADMIN_SOCKET_PORT=4001
ENABLE_ADMIN_INTERFACE=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug

# Vercel/Production Settings
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
# For production: https://your-backend-domain.com
