# Solana Flashloan Arbitrage Configuration

# Environment
NODE_ENV=development
PORT=4000

# Solana Network Configuration
SOLANA_NETWORK=devnet
# Options: devnet, mainnet-beta, testnet

# Program IDs
PROGRAM_ID=F1ash1oanArb1trag3Program11111111111111111

# RPC Endpoints (Premium - validate before production use)
# Helius
HELIUS_RPC_URL=

# QuickNode
QUICKNODE_RPC_URL=

# Triton
TRITON_RPC_URL=

# Alchemy
ALCHEMY_RPC_URL=

# Network Optimization
ENABLE_IP_ROTATION=false
ENABLE_VPN=false
PROXY_LIST=

# Example proxy format: http://user:pass@proxy1.example.com:8080,http://proxy2.example.com:8080

# Security
KEY_ENCRYPTION_KEY=change-this-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
REQUIRE_AUTH=false

# Fee Configuration
MIN_TIP_LAMPORTS=1000
MAX_TIP_LAMPORTS=100000
PRIORITY_FEE_PERCENTILE=75

# Jito Configuration
JITO_TIP_ACCOUNT=
JITO_BLOCK_ENGINE_URL=

# Admin Configuration
ADMIN_SOCKET_PORT=4001
ENABLE_ADMIN_INTERFACE=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug
