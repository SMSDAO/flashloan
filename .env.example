# Solana Flashloan Arbitrage Configuration
# Auto-configured with sensible defaults for quick setup

# Environment
NODE_ENV=development
PORT=4000

# -----------------------------------------------------------------------------
# FRONTEND CONFIGURATION (for Vercel/Production deployment)
# -----------------------------------------------------------------------------

# Backend URL - Used by frontend to connect to backend API
# Development: Leave empty (defaults to http://localhost:4000)
# Production: Set to your deployed backend URL
NEXT_PUBLIC_BACKEND_URL=

# For Vercel: Also set $BACKEND_URL in Vercel project environment variables
# This is used by vercel.json rewrites

# -----------------------------------------------------------------------------
# SOLANA NETWORK CONFIGURATION
# -----------------------------------------------------------------------------

SOLANA_NETWORK=devnet
# Options: devnet, mainnet-beta, testnet

# Program IDs
PROGRAM_ID=F1ash1oanArb1trag3Program11111111111111111

# RPC Endpoints (Premium - validate before production use)
# Helius - Get your key at https://helius.dev
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# QuickNode - Get your endpoint at https://quicknode.com
QUICKNODE_RPC_URL=https://your-endpoint.solana-devnet.quiknode.pro/YOUR_TOKEN/

# Triton - Get your endpoint at https://triton.one
TRITON_RPC_URL=https://your-endpoint.rpcpool.com/YOUR_TOKEN

# Alchemy - Get your key at https://alchemy.com
ALCHEMY_RPC_URL=https://solana-devnet.g.alchemy.com/v2/YOUR_API_KEY

# Network Optimization
ENABLE_IP_ROTATION=false
ENABLE_VPN=false
PROXY_LIST=

# Example proxy format: http://user:pass@proxy1.example.com:8080,http://proxy2.example.com:8080

# Security
KEY_ENCRYPTION_KEY=auto-generated-dev-key-replace-in-production-with-secure-random-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-domain.vercel.app
REQUIRE_AUTH=false

# Fee Configuration (Dynamic Optimization)
MIN_TIP_LAMPORTS=1000
MAX_TIP_LAMPORTS=100000
PRIORITY_FEE_PERCENTILE=75
# Percentile of recent priority fees to use (0-100). Higher = faster execution, more cost
DYNAMIC_FEE_MULTIPLIER=1.2
# Multiplier applied to base fee for competitive positioning

# Jito MEV Configuration
ENABLE_JITO_BUNDLES=true
JITO_TIP_ACCOUNT=T1pXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Get Jito tip account from https://jito.wtf
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
# For devnet: https://amsterdam.mainnet.block-engine.jito.wtf/api/v1/bundles
JITO_BUNDLE_TIP_LAMPORTS=10000
# Tip amount for Jito bundles (10000 lamports = 0.00001 SOL)
JITO_MAX_RETRIES=3
# Number of retry attempts for Jito bundle submission

# MEV Protection Settings
MEV_PROTECTION_ENABLED=true
MEV_SLIPPAGE_BPS=50
# Maximum slippage in basis points (50 bps = 0.5%)
MEV_MIN_PROFIT_LAMPORTS=5000
# Minimum profit threshold to execute arbitrage

# Arbitrage Configuration
MIN_PROFIT_THRESHOLD=0.001
# Minimum profit as fraction of trade amount (0.001 = 0.1%)
MAX_SLIPPAGE=0.005
# Maximum acceptable slippage (0.005 = 0.5%)
EXECUTION_TIMEOUT_MS=30000
# Maximum time to wait for transaction confirmation

# Admin Configuration
ADMIN_SOCKET_PORT=4001
ENABLE_ADMIN_INTERFACE=true
ADMIN_API_KEY=your-secure-admin-api-key-here
# Generate with: openssl rand -hex 32

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_EXECUTION_TIMELINE=true
ENABLE_PROFIT_EVENTS=true

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug
LOG_FORMAT=json
# Options: json, text
ENABLE_STRUCTURED_LOGS=true

# RPC Fallback Configuration
ENABLE_RPC_FALLBACK=true
RPC_HEALTH_CHECK_INTERVAL=30000
# Interval in ms to check RPC health (30000 = 30 seconds)
RPC_MAX_RETRIES=3
# Number of RPC fallback attempts before failing

# Rate Limiting
ENABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_MS=60000
# Time window for rate limiting (60000 = 1 minute)
RATE_LIMIT_MAX_REQUESTS=100
# Maximum requests per window

# Vercel/Production Settings
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
# For production: https://your-backend-domain.com

# Database (Optional - for persistence)
DATABASE_URL=
# Example: postgresql://user:password@host:5432/database

# Redis (Optional - for caching)
REDIS_URL=
# Example: redis://localhost:6379
