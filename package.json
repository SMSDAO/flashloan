{
  "name": "flashloan-arbitrage-2026",
  "version": "2.0.0",
  "description": "Production-grade 2026 Solana Flashloan Arbitrage System",
  "main": "index.js",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm-run-all build:*",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:program": "cargo build-bpf --manifest-path=programs/flashloan-arbitrage/Cargo.toml",
    "test": "npm-run-all test:*",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "lint": "npm-run-all lint:*",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "start": "npm-run-all --parallel start:*",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start",
    "setup": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "setup:env": "./scripts/setup-env.sh",
    "setup:all": "npm run setup:env && npm run setup",
    "deploy:devnet": "solana program deploy target/deploy/flashloan_arbitrage.so --url devnet",
    "deploy:mainnet": "solana program deploy target/deploy/flashloan_arbitrage.so --url mainnet-beta",
    "deploy:vercel": "vercel --prod"
  },
  "workspaces": [
    "backend",
    "frontend",
    "desktop-admin"
  ],
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "npm-run-all": "^4.1.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "hardhat": "^3.0.4"
  }
}